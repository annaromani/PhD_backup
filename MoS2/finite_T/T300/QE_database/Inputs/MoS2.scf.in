&control
    calculation = 'scf',
    restart_mode='from_scratch',
    prefix='MoS2',
    pseudo_dir = '../../pseudo/',
    verbosity='high',
/
&system
    ibrav=4,
    celldm(1)=5.94774857
    celldm(3)=6.72523384    
    nat=3,
    ntyp=2,
    ecutwfc=80.0,
    assume_isolated='2D',
/
&electrons
    diagonalization='david',
    conv_thr=1.0d-15
/
ATOMIC_SPECIES
Mo 95.95 Mo.pbesol.dojo.upf
S 32.065 S.pbesol.dojo.upf
ATOMIC_POSITIONS crystal
Mo               0.3333333000        0.6666666000        0.0000000000
S                0.6666666666        0.3333333333        0.0735295469    0   0   1
S                0.6666666666        0.3333333333       -0.0735295469    0   0   1
K_POINTS automatic
18 18 1 0 0 0
