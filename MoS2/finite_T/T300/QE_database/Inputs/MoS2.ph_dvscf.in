&inputph
           verbosity = 'high'
              tr2_ph = 1e-12
              prefix = 'MoS2'
            fildvscf = 'MoS2-dvscf'
	      fildyn = 'MoS2.dyn.xml',       
     electron_phonon = 'dvscf',
               epsil = .true.
               trans = .true.
               ldisp = .false.
               qplot = .true.
             recover = .true.
	alpha_mix(1) = 0.1
/
