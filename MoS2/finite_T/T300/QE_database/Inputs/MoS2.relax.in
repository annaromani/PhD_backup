&control
    calculation = 'relax',
    restart_mode='from_scratch',
    prefix='MoS2',
    pseudo_dir = '../pseudo/',
    outdir='./tmp/',
    verbosity='high',
    etot_conv_thr = 1.0d-10,
    forc_conv_thr = 1.0d-7,

/
&system
    ibrav=4,
    celldm(1)=5.94774857
    celldm(3)=6.72523384    
    nat=3,
    ntyp=2,
    ecutwfc=100.0,
    ecutrho = 800.0,
    nr1 = 60, nr2 = 60, nr3 = 420, ! specific grid to be multiple of the cell 
    nr1s = 48, nr2s = 48, nr3s = 300
/
&electrons
    diagonalization='david',
    startingpot='file',
    mixing_mode='local-TF',
    mixing_beta=0.3
    conv_thr=1.0d-15
/
&ions
    ion_dynamics='bfgs'
/
ATOMIC_SPECIES
Mo 95.95 Mo.pbesol.dojo.upf
S 32.065 S.pbesol.dojo.upf
ATOMIC_POSITIONS crystal
Mo  0.333333333333  0.666666666667  0.000000000000
S   0.666666666667  0.333333333333  0.073633019833  0 0 1
S   0.666666666667  0.333333333333 -0.073633019833  0 0 1
K_POINTS automatic
18 18 1 0 0 0

